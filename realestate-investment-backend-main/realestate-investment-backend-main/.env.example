PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb://127.0.0.1:27017/hive_advisor
JWT_SECRET=replace_with_backend_jwt_secret
JWT_EXPIRES_IN=1d
CORS_ORIGIN=http://localhost:3000
